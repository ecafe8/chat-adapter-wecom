# Required WeCom intelligent robot credentials.
WECOM_BOT_ID=replace-with-wecom-bot-id
WECOM_BOT_SECRET=replace-with-wecom-long-connection-secret

# Optional transport tuning.
WECOM_WS_URL=wss://openws.work.weixin.qq.com
WECOM_HEARTBEAT_INTERVAL_MS=30000
WECOM_RECONNECT_DELAY_MS=1000
WECOM_MAX_RECONNECT_DELAY_MS=30000

# Optional native streaming tuning.
# Maximum stream lifetime before forced finalization. WeCom ends streams
# after 10 minutes; this must stay at or below that limit.
WECOM_STREAM_DEADLINE_MS=540000
# Minimum interval (ms) between stream update frames. WeCom limits each
# conversation to 30 messages/minute, 1000/hour (replies + proactive pushes
# combined), so batch rapid chunks to stay under that limit.
WECOM_STREAM_COALESCE_MS=1000
